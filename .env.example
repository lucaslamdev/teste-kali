# Nome exibido no Cursor (My Machines) — obrigatório para identificar o worker
WORKER_NAME=kali-docker-worker

# Nome do container Docker no host
CONTAINER_NAME=kali-cursor-worker

# Diretório no host montado em /workspace (deve ser um repositório git)
WORKER_DIR=.

# Imagem Docker local (gerada pelo build)
IMAGE_NAME=kali-cursor-worker:latest

# Autenticação do worker (obrigatório — escolha uma opção)
# Opção A: API key no .env (recomendado para automação)
# Obtenha em: https://cursor.com/dashboard → API Keys
CURSOR_API_KEY=

# Opção B: login no navegador (não preencha CURSOR_API_KEY)
#   python install_kali.py login
#   (ou responda [2] quando o install perguntar)

# Opcional: diretório de trabalho dentro do container (padrão: /workspace)
# CURSOR_WORKER_DIR=/workspace
